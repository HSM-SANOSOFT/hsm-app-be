{
  "name": "hsm-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev:api": "pnpm --filter @hsm/api start:dev",
    "dev:worker": "pnpm --filter @hsm/worker start:dev",
    "start:api:dev": "pnpm --filter @hsm/api start:dev",
    "start:api:debug": "pnpm --filter @hsm/api start:debug",
    "start:api:prod": "pnpm --filter @hsm/api start:prod",
    "start:worker:dev": "pnpm --filter @hsm/worker start:dev",
    "start:worker:debug": "pnpm --filter @hsm/worker start:debug",
    "start:worker:prod": "pnpm --filter @hsm/worker start:prod",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "turbo test",
    "test:cov": "turbo test:cov",
    "prepare": "husky",
    "generator:entity": "ts-node -r tsconfig-paths/register packages/database/src/generator/generators/entity.generator.ts",
    "generator:schema": "ts-node -r tsconfig-paths/register packages/database/src/generator/generators/schema.generator.ts",
    "generator:test:query": "ts-node -r tsconfig-paths/register packages/database/src/generator/tests/query.test.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.4"
  }
}
