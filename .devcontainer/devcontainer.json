{
  "name": "HSM App Dev Container",
  "dockerComposeFile": "../docker/docker-compose.yaml",
  "service": "hsm-app-be-server",
  "runServices": [
    "hsm-app-db-postgres",
    "hsm-app-db-redis",
    "hsm-app-db-minio",
    "hsm-app-db-console-redis",
    "hsm-app-db-console-pgadmin"
  ],
  "workspaceFolder": "/app",
  "forwardPorts": [
    10001,
    10002,
    10003,
    10004,
    10005,
    10006,
    10007,
    10008
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "ms-azuretools.vscode-docker",
        "firsttris.vscode-jest-runner"
      ]
    }
  }
}